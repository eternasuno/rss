{
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "extends": ["../../biome.json"],
  "linter": {
    "rules": {
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": {
            "maxLines": 40
          }
        }
      },
      "style": {
        "noExcessiveLinesPerFile": {
          "level": "warn",
          "options": {
            "maxLines": 200
          }
        }
      }
    }
  }
}
