{
  "compilerOptions": {
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client"]
  },
  "include": ["server", "src", "test", "pages"]
}
